{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "crons": [
    { "path": "/api/rfp-monitor", "schedule": "0 */6 * * *" },
    { "path": "/api/followup-cron", "schedule": "0 * * * *" },
    { "path": "/api/briefing-cron", "schedule": "0 * * * *" }
  ]
}
